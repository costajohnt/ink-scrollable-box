# Children mode — styled React nodes with colors
Output media/children-mode.gif
Set Shell "bash"
Set Width 80
Set Height 24
Set FontSize 14
Set Theme "Dracula"
Set Padding 10

Type "npx tsx examples/children-mode.tsx"
Enter
Sleep 1.5s

# Scroll through colored items
Type "j"
Sleep 400ms
Type "j"
Sleep 400ms
Type "j"
Sleep 400ms
Type "j"
Sleep 400ms
Type "j"
Sleep 400ms
Type "j"
Sleep 400ms

# Back to top
Type "g"
Sleep 1s

# Jump to bottom
Type "G"
Sleep 1s

# Exit
Ctrl+C
Sleep 500ms
