{
  "name": "ink-scrollable-box",
  "version": "1.0.0",
  "description": "Scrollable container component for Ink with keyboard navigation, vim bindings, and auto-follow",
  "keywords": [
    "ink",
    "react",
    "cli",
    "terminal",
    "scroll",
    "scrollable",
    "scrollbar",
    "viewport",
    "tui",
    "vim",
    "keyboard"
  ],
  "author": "John Costa",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/costajohnt/ink-scrollable-box"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "xo",
    "lint:fix": "xo --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "ink": ">=4.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "ink": "^6.8.0",
    "ink-testing-library": "^4.0.0",
    "react": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2",
    "xo": "^2.0.2"
  }
}
